<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppNotasMaui.Views.EditPage"
             Title="EditPage">
    <VerticalStackLayout>
        <Label 
        Text="Edita tu nota"
        VerticalOptions="Center" 
        HorizontalOptions="Center" />

        <CheckBox 
            x:Name="FavoriteCheck"
            CheckedChanged="FavoriteCheck_CheckedChanged"
            IsChecked="{Binding IsFavourited}">

        </CheckBox>
        <Label 
            Text="Marcar como favorito"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        
        <Editor
            x:Name="TitleEntry"
            Text="{Binding Title}"
            Placeholder="Agrega un titulo a tu nota...">
        </Editor>
        
        <Editor
            x:Name="ContentEntry"
            Placeholder="Agrega el contenido a tu nota...">
        </Editor>
        
        <Button 
            Text="Guardar"
            Clicked="Save_Clicked">
        </Button>
        <Button 
            
            Text="Borrar"
            Clicked="Delete_Clicked">
        </Button>

        <Button 
            Text="Cancelar"
            Clicked="Cancel_Clicked">
        </Button>
        
    </VerticalStackLayout>
</ContentPage>