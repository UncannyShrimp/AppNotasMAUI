<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppNotasMaui.Controls"
             x:Class="AppNotasMaui.Views.EditPage"
             Title="Editar Nota"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#0F1117}"
             Padding="0">

    <ContentPage.Resources>
        <ResourceDictionary>


            <Color x:Key="Primary">#3B82F6</Color>
            <Color x:Key="PrimaryDark">#2563EB</Color>
            <Color x:Key="AccentYellow">#F59E0B</Color>
            <Color x:Key="DangerRed">#EF4444</Color>
            <Color x:Key="CardLight">#F9FAFB</Color>
            <Color x:Key="CardDark">#1F2937</Color>
            <Color x:Key="TextPrimaryLight">#111827</Color>
            <Color x:Key="TextPrimaryDark">White</Color>
            <Color x:Key="TextSecondaryLight">#6B7280</Color>
            <Color x:Key="TextSecondaryDark">#D1D5DB</Color>
            <Color x:Key="BorderLight">#E5E7EB</Color>
            <Color x:Key="BorderDark">#374151</Color>

        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">


        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                StrokeThickness="0"
                Padding="16,12"
                Margin="0">
            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Editar Nota"
                       FontSize="Title"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">

            <VerticalStackLayout Spacing="20" Padding="16,16,16,140">


                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                        Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16">

                    <Border.Shadow>
                        <Shadow Brush="#000000"
                                Radius="10"
                                Offset="0,3"
                                Opacity="0.25"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">


                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto">

                            <Editor x:Name="TitleEntry"
                                    Text="{Binding Title}"
                                    Placeholder="Título de la nota..."
                                    FontSize="Large"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                    PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                                    BackgroundColor="Transparent"
                                    Margin="0,-8,0,-8"
                                    HorizontalOptions="Fill" />

                            <controls:StarCheckBox x:Name="FavoriteCheck"
                                                   Grid.Column="1"
                                                   IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="End"
                                                   Scale="0.7" />
                        </Grid>


                        <Editor x:Name="ContentEntry"
                                Text="{Binding Content}"
                                Placeholder="Escribe tu nota aquí..."
                                AutoSize="TextChanges"
                                MinimumHeightRequest="200"
                                FontSize="Medium"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                                PlaceholderColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}"
                                BackgroundColor="Transparent"
                                Margin="0,-4,0,0" />


                        <VerticalStackLayout Spacing="4" Margin="0,8,0,0">
                            <Label 
                                   x:Name="CreateDate"
                                   Text="{Binding CreatedAt, StringFormat='Creado: {0:dd MMM yyyy HH:mm}'}"
                                   FontSize="Caption"
                                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}" />

                            <Label 
                                   x:Name="UpdateDate"
                                   Text="{Binding UpdatedAt, StringFormat='Última edición: {0:dd MMM yyyy HH:mm}'}"
                                   FontSize="Caption"
                                   TextColor="{AppThemeBinding Light=#9CA3AF, Dark=#6B7280}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>


                <BoxView HeightRequest="60" BackgroundColor="{AppThemeBinding Light=White, Dark=#0F1117}" />

            </VerticalStackLayout>
        </ScrollView>


        <HorizontalStackLayout 
    Grid.Row="1"
    VerticalOptions="End"
    HorizontalOptions="Fill"
    Padding="16"
    Spacing="12"
    BackgroundColor="{AppThemeBinding Light=White, Dark=#0F1117}"
    Margin="0,0,0,16">

            <Button Text="Cancelar"
            Clicked="Cancel_Clicked"
            FontSize="Medium"
            TextColor="{StaticResource TextSecondaryLight}"
            BackgroundColor="Transparent"
            BorderColor="{StaticResource BorderLight}"
            BorderWidth="1"
            CornerRadius="12"
            Padding="16,10"
            MinimumWidthRequest="100" />

            <Button Text="Guardar"
            Clicked="Save_Clicked"
            FontSize="Medium"
            TextColor="White"
            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
            CornerRadius="12"
            Padding="16,10"
            MinimumWidthRequest="100" />

            <Button Text="Borrar"
            Clicked="Delete_Clicked"
            FontSize="Medium"
            TextColor="White"
            BackgroundColor="{StaticResource DangerRed}"
            CornerRadius="12"
            Padding="16,10"
            MinimumWidthRequest="100" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>